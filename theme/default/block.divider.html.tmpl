{{ if .Block.Label }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;">
	<tr>
		<td width="50%" style="padding:0 8px 0 {{ .Block.Inset }}px;vertical-align:middle;"><hr style="border:0;border-top:{{ .Block.Thickness }}px {{ .Block.Variant }} {{ .Values.Styles.ColorBorder }};margin:0;" /></td>
		<td style="white-space:nowrap;vertical-align:middle;text-align:center;font-size:11px;font-weight:600;color:{{ .Values.Styles.ColorTextMuted }};text-transform:uppercase;letter-spacing:0.08em;line-height:1;">{{ .Block.Label }}</td>
		<td width="50%" style="padding:0 {{ .Block.Inset }}px 0 8px;vertical-align:middle;"><hr style="border:0;border-top:{{ .Block.Thickness }}px {{ .Block.Variant }} {{ .Values.Styles.ColorBorder }};margin:0;" /></td>
	</tr>
</table>
{{ else }}
<hr style="border:0;border-top:{{ .Block.Thickness }}px {{ .Block.Variant }} {{ .Values.Styles.ColorBorder }};margin:24px {{ .Block.Inset }}px;" />
{{ end }}