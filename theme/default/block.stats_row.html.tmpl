{{ if .Block.Header }}<p style="margin:0 0 8px;font-weight:700;color:{{ .Values.Styles.ColorText }};">{{ .Block.Header }}</p>{{ end }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin:0 0 16px;">
  <tr>
    {{ range .Block.Stats }}
    <td valign="top" style="padding:8px 10px;border:1px solid {{ $.Values.Styles.ColorBorder }};">
      <p style="margin:0 0 4px;color:{{ $.Values.Styles.ColorText }};font-size:20px;font-weight:700;">{{ .Value }}</p>
      <p style="margin:0;color:{{ $.Values.Styles.ColorTextMuted }};font-size:13px;">{{ .Label }}</p>
      {{ if .Delta }}<p style="margin:4px 0 0;color:{{ if eq .DeltaSemantic "positive" }}#15803d{{ else if eq .DeltaSemantic "negative" }}#b91c1c{{ else }}{{ $.Values.Styles.ColorTextMuted }}{{ end }};font-size:12px;font-weight:{{ if eq .DeltaSemantic "none" }}400{{ else }}600{{ end }};">{{ .Delta }}</p>{{ end }}
    </td>
    {{ end }}
  </tr>
</table>
