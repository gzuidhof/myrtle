{{ if .Block.Header }}<p style="margin:0 0 8px;font-weight:700;color:{{ .Values.Styles.TextColor }};">{{ .Block.Header }}</p>{{ end }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin:0 0 16px;">
  {{ range .Block.Pairs }}
  <tr>
    <td style="padding:6px 0;color:{{ $.Values.Styles.MutedTextColor }};vertical-align:top;">{{ .Key }}</td>
    <td style="padding:6px 0;color:{{ $.Values.Styles.TextColor }};font-weight:600;vertical-align:top;text-align:right;">{{ .Value }}</td>
  </tr>
  {{ end }}
</table>
