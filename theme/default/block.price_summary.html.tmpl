<div style="margin:0 0 16px;padding:12px 14px;border:1px solid {{ .Values.Styles.ColorBorder }};border-radius:{{ if eq .Block.InsetMode "none" }}0{{ else }}{{ .Values.Styles.RadiusElement }}{{ end }};{{ if eq .Block.InsetMode "none" }}border-left:0;border-right:0;{{ end }}background:{{ .Values.Styles.ColorSurface }};">
  {{ if .Block.Header }}<p style="margin:0 0 10px;font-weight:700;color:{{ .Values.Styles.ColorText }};">{{ .Block.Header }}</p>{{ end }}
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;">
  {{ range .Block.Items }}
  <tr>
    <td style="padding:0 12px 6px 0;color:{{ $.Values.Styles.ColorText }};vertical-align:top;">{{ .Label }}</td>
    <td align="right" style="padding:0 0 6px;text-align:right;white-space:nowrap;color:{{ $.Values.Styles.ColorText }};vertical-align:top;">
      {{ if isDiscountLike .Label .Value }}<span style="color:{{ $.Values.Styles.ColorPrimary }};font-weight:600;">{{ .Value }}</span>{{ else }}{{ .Value }}{{ end }}
    </td>
  </tr>
  {{ end }}
  {{ if or .Block.TotalLabel .Block.TotalValue }}
  <tr>
    <td style="padding:10px 12px 0 0;border-top:1px solid {{ .Values.Styles.ColorBorder }};font-weight:700;color:{{ .Values.Styles.ColorText }};vertical-align:top;">{{ .Block.TotalLabel }}</td>
    <td align="right" style="padding:10px 0 0;border-top:1px solid {{ .Values.Styles.ColorBorder }};text-align:right;white-space:nowrap;font-weight:700;color:{{ .Values.Styles.ColorText }};vertical-align:top;">{{ .Block.TotalValue }}</td>
  </tr>
  {{ end }}
  </table>
</div>
