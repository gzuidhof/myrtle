<p style="margin:{{ if .Block.NoMargin }}0{{ else }}0 0 16px{{ end }};line-height:{{ if eq .Block.Spacing "compact" }}1.4{{ else if eq .Block.Spacing "relaxed" }}1.8{{ else }}1.6{{ end }};color:{{ toneColor .Block.Tone .Values "text" }};{{ if eq .Block.Size "small" }}font-size:13px;{{ else if eq .Block.Size "large" }}font-size:16px;{{ end }}text-align:{{ physicalAlign .Block.Align .Values }};{{ if eq .Block.Weight "medium" }}font-weight:500;{{ else if eq .Block.Weight "semibold" }}font-weight:600;{{ else if eq .Block.Weight "bold" }}font-weight:700;{{ else if eq .Block.Weight "normal" }}font-weight:400;{{ end }}{{ if eq .Block.Transform "uppercase" }}text-transform:uppercase;{{ else if eq .Block.Transform "lowercase" }}text-transform:lowercase;{{ else if eq .Block.Transform "capitalize" }}text-transform:capitalize;{{ end }}">{{ .Block.Text }}</p>