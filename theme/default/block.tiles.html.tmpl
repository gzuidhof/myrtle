<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:separate;border-spacing:8px;margin:0 0 16px;">
  {{ range .Rows }}
  <tr>
    {{ range . }}
    <td width="{{ $.ColumnWidth }}%" valign="top" style="padding:0;">
      <div style="height:100%;box-sizing:border-box;padding:{{ if .Content }}10px 12px 12px{{ else }}8px{{ end }};border-radius:{{ $.Values.Styles.RadiusElement }};{{ if eq .Variant "highlight" }}border:1px solid {{ $.Values.Styles.ColorInfoBorder }};{{ if $.Block.TransparentBackground }}background:transparent;{{ else }}background:{{ $.Values.Styles.ColorInfoBackground }};{{ end }}{{ else if eq .Variant "success" }}border:1px solid {{ $.Values.Styles.ColorSuccessBorder }};{{ if $.Block.TransparentBackground }}background:transparent;{{ else }}background:{{ $.Values.Styles.ColorSuccessBackground }};{{ end }}{{ else if eq .Variant "warning" }}border:1px solid {{ $.Values.Styles.ColorWarningBorder }};{{ if $.Block.TransparentBackground }}background:transparent;{{ else }}background:{{ $.Values.Styles.ColorWarningBackground }};{{ end }}{{ else if eq .Variant "critical" }}border:1px solid {{ $.Values.Styles.ColorDangerBorder }};{{ if $.Block.TransparentBackground }}background:transparent;{{ else }}background:{{ $.Values.Styles.ColorDangerBackground }};{{ end }}{{ else }}{{ if $.Block.Border }}border:1px solid {{ $.Values.Styles.ColorBorder }};{{ else }}border:1px solid transparent;{{ end }}{{ if $.Block.TransparentBackground }}background:transparent;{{ else }}background:{{ $.Values.Styles.ColorSurfaceMuted }};{{ end }}{{ end }}text-align:{{ physicalAlign $.Block.Alignment $.Values }};">
        {{ if .Content }}<div style="width:84px;height:84px;line-height:84px;margin:{{ if eq $.Block.Alignment "start" }}{{ if isRTL $.Values }}0 0 6px auto{{ else }}0 0 6px{{ end }}{{ else if eq $.Block.Alignment "end" }}{{ if isRTL $.Values }}0 0 6px{{ else }}0 0 6px auto{{ end }}{{ else }}0 auto 6px{{ end }};border-radius:{{ $.Values.Styles.RadiusElement }};font-size:40px;font-weight:700;color:{{ $.Values.Styles.ColorText }};">{{ .Content }}</div>{{ end }}
        {{ if .Title }}<p style="margin:0 0 4px;color:{{ $.Values.Styles.ColorText }};font-weight:700;line-height:1.4;">{{ if .URL }}<a href="{{ .URL }}" style="color:{{ $.Values.Styles.ColorText }};text-decoration:underline;">{{ .Title }}</a>{{ else }}{{ .Title }}{{ end }}</p>{{ end }}
        {{ if .Subtitle }}<p style="margin:0;color:{{ $.Values.Styles.ColorTextMuted }};font-size:13px;line-height:1.4;">{{ .Subtitle }}</p>{{ end }}
      </div>
    </td>
    {{ end }}
  </tr>
  {{ end }}
</table>
