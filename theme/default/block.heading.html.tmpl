{{ if eq .Block.Level 1 }}
<h1 style="margin:0 0 12px;color:{{ .Values.Styles.ColorText }};font-size:30px;line-height:1.25;font-weight:{{ .Values.Styles.FontWeightHeading }};">{{ .Block.Text }}</h1>
{{ else if eq .Block.Level 3 }}
<h3 style="margin:0 0 12px;color:{{ .Values.Styles.ColorText }};font-size:20px;line-height:1.35;font-weight:{{ .Values.Styles.FontWeightHeading }};">{{ .Block.Text }}</h3>
{{ else if eq .Block.Level 4 }}
<h4 style="margin:0 0 12px;color:{{ .Values.Styles.ColorText }};font-size:18px;line-height:1.4;font-weight:{{ .Values.Styles.FontWeightHeading }};">{{ .Block.Text }}</h4>
{{ else if eq .Block.Level 5 }}
<h5 style="margin:0 0 12px;color:{{ .Values.Styles.ColorText }};font-size:16px;line-height:1.4;font-weight:{{ .Values.Styles.FontWeightHeading }};">{{ .Block.Text }}</h5>
{{ else if eq .Block.Level 6 }}
<h6 style="margin:0 0 12px;color:{{ .Values.Styles.ColorText }};font-size:14px;line-height:1.45;font-weight:{{ .Values.Styles.FontWeightHeading }};">{{ .Block.Text }}</h6>
{{ else }}
<h2 style="margin:0 0 12px;color:{{ .Values.Styles.ColorText }};font-size:24px;line-height:1.3;font-weight:{{ .Values.Styles.FontWeightHeading }};">{{ .Block.Text }}</h2>
{{ end }}
