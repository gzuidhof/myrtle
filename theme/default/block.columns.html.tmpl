<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin:0 0 16px;">
  <tr>
    <td width="{{ .Block.LeftWidth }}%" valign="top" style="padding:0 8px 0 0;">
      {{ safe .LeftHTML }}
    </td>
    <td width="{{ .Block.RightWidth }}%" valign="top" style="padding:0 0 0 8px;">
      {{ safe .RightHTML }}
    </td>
  </tr>
</table>
