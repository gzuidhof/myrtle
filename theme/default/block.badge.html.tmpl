<p style="margin:0 0 14px;">
  <span style="display:inline-block;padding:4px 10px;border-radius:{{ .Values.Styles.RadiusPill }};font-size:12px;font-weight:700;background:{{ if eq .Block.Tone "success" }}{{ .Values.Styles.ColorSuccessBackground }}{{ else if eq .Block.Tone "warning" }}{{ .Values.Styles.ColorWarningBackground }}{{ else if eq .Block.Tone "error" }}{{ .Values.Styles.ColorDangerBackground }}{{ else }}{{ .Values.Styles.ColorInfoBackground }}{{ end }};color:{{ if eq .Block.Tone "success" }}{{ .Values.Styles.ColorSuccessText }}{{ else if eq .Block.Tone "warning" }}{{ .Values.Styles.ColorWarningText }}{{ else if eq .Block.Tone "error" }}{{ .Values.Styles.ColorDangerText }}{{ else }}{{ .Values.Styles.ColorInfoText }}{{ end }};">{{ .Block.Text }}</span>
</p>
