<p style="margin:0 0 14px;">
  <span style="display:inline-block;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:700;background:{{ if eq .Block.Tone "success" }}#ecfdf5{{ else if eq .Block.Tone "warning" }}#fffbeb{{ else if eq .Block.Tone "error" }}#fef2f2{{ else }}#eff6ff{{ end }};color:{{ if eq .Block.Tone "success" }}#065f46{{ else if eq .Block.Tone "warning" }}#92400e{{ else if eq .Block.Tone "error" }}#991b1b{{ else }}#1d4ed8{{ end }};">{{ .Block.Text }}</span>
</p>
