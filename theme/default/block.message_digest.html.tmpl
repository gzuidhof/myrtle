<section style="margin:0 0 16px;padding:12px 14px;border:1px solid {{ .Values.Styles.ColorBorder }};border-radius:{{ .Values.Styles.RadiusElement }};background:{{ .Values.Styles.ColorSurface }};">
  {{ if .Block.Title }}<p style="margin:0 0 6px;color:{{ .Values.Styles.ColorText }};font-weight:700;font-size:16px;">{{ .Block.Title }}</p>{{ end }}
  {{ if .SubtitleHTML }}<div style="margin:0 0 10px;color:{{ .Values.Styles.ColorTextMuted }};font-size:13px;line-height:1.45;">{{ .SubtitleHTML }}</div>{{ end }}
  {{ if .Items }}
    {{ range $index, $item := .Items }}
      <div style="{{ if gt $index 0 }}margin-top:16px;padding-top:16px;border-top:1px solid {{ $.Values.Styles.ColorBorder }};{{ end }}">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
          <tr>
            {{ if $.HasAvatar }}
            <td valign="top" style="width:40px;{{ if isRTL $.Values }}padding:0 0 0 10px;{{ else }}padding:0 10px 0 0;{{ end }}">
                {{ if $item.Block.AvatarURL }}
                  {{ if $item.Block.LogoHref }}<a href="{{ $item.Block.LogoHref }}" style="display:block;text-decoration:none;">{{ end }}
                  <img src="{{ $item.Block.AvatarURL }}" alt="{{ $item.Block.LogoAlt }}" width="36" height="36" style="display:block;width:36px;height:36px;border-radius:{{ $.Values.Styles.RadiusElement }};object-fit:cover;" />
                  {{ if $item.Block.LogoHref }}</a>{{ end }}
                {{ else }}
                  <div style="width:36px;height:36px;">&nbsp;</div>
                {{ end }}
            </td>
            {{ end }}
            <td valign="top" style="padding:0;">
              {{ if $item.SubjectHTML }}<div style="margin:0 0 4px;color:{{ $.Values.Styles.ColorText }};font-weight:700;line-height:1.4;">{{ if $item.Block.URL }}<a href="{{ $item.Block.URL }}" style="color:{{ $.Values.Styles.ColorText }};text-decoration:none;">{{ $item.SubjectHTML }}</a>{{ else }}{{ $item.SubjectHTML }}{{ end }}</div>{{ end }}
              {{ if $item.PreviewHTML }}<div style="margin:0 0 6px;color:{{ $.Values.Styles.ColorText }};line-height:1.5;">{{ $item.PreviewHTML }}</div>{{ end }}
              {{ if $item.MetaLine }}<p style="margin:0;color:{{ $.Values.Styles.ColorTextMuted }};font-size:12px;line-height:1.4;">{{ $item.MetaLine }}</p>{{ end }}
              {{ if and $item.Block.ActionLabel $item.Block.ActionURL }}<p style="margin:8px 0 0;"><a href="{{ $item.Block.ActionURL }}" style="color:{{ $.Values.Styles.ColorPrimary }};text-decoration:none;font-weight:600;">{{ $item.Block.ActionLabel }}</a></p>{{ end }}
            </td>
          </tr>
        </table>
      </div>
    {{ end }}
  {{ else if .Block.EmptyText }}
    <p style="margin:0;color:{{ .Values.Styles.ColorTextMuted }};line-height:1.5;">{{ .Block.EmptyText }}</p>
  {{ end }}
  {{ if .FooterHTML }}<div style="margin:10px 0 0;padding-top:10px;border-top:1px solid {{ .Values.Styles.ColorBorder }};color:{{ .Values.Styles.ColorTextMuted }};font-size:12px;line-height:1.45;">{{ .FooterHTML }}</div>{{ end }}
</section>
