<div style="margin:0 0 16px;padding:12px 14px;border-radius:{{ .Values.Styles.RadiusElement }};border:1px solid {{ if or (eq .Block.Type "error") (eq .Block.Type "critical") }}{{ .Values.Styles.ColorDangerBorder }}{{ else if eq .Block.Type "success" }}{{ .Values.Styles.ColorSuccessBorder }}{{ else if eq .Block.Type "warning" }}{{ .Values.Styles.ColorWarningBorder }}{{ else }}{{ .Values.Styles.ColorInfoBorder }}{{ end }};{{ if eq .Block.Variant "outline" }}background:{{ .Values.Styles.ColorSurface }};{{ else if eq .Block.Variant "solid" }}{{ if or (eq .Block.Type "error") (eq .Block.Type "critical") }}background:{{ .Values.Styles.ColorDanger }};color:{{ .Values.Styles.ColorTextOnSolid }};{{ else if eq .Block.Type "success" }}background:{{ .Values.Styles.ColorSuccess }};color:{{ .Values.Styles.ColorTextOnSolid }};{{ else if eq .Block.Type "warning" }}background:{{ .Values.Styles.ColorWarning }};color:{{ .Values.Styles.ColorTextOnSolid }};{{ else }}background:{{ .Values.Styles.ColorInfo }};color:{{ .Values.Styles.ColorTextOnSolid }};{{ end }}{{ else }}background:{{ if or (eq .Block.Type "error") (eq .Block.Type "critical") }}{{ .Values.Styles.ColorDangerBackground }}{{ else if eq .Block.Type "success" }}{{ .Values.Styles.ColorSuccessBackground }}{{ else if eq .Block.Type "warning" }}{{ .Values.Styles.ColorWarningBackground }}{{ else }}{{ .Values.Styles.ColorInfoBackground }}{{ end }};{{ end }}">
  {{ if .Block.Title }}<p style="margin:0 0 6px;font-weight:700;color:{{ if eq .Block.Variant "solid" }}{{ .Values.Styles.ColorTextOnSolid }}{{ else }}{{ .Values.Styles.ColorText }}{{ end }};">{{ .Block.Title }}</p>{{ end }}
  {{ if .Block.Body }}<p style="margin:0;color:{{ if eq .Block.Variant "solid" }}{{ .Values.Styles.ColorTextOnSolid }}{{ else }}{{ .Values.Styles.ColorText }}{{ end }};line-height:1.5;">{{ .Block.Body }}</p>{{ end }}
  {{ if and .Block.LinkLabel .Block.LinkURL }}<p style="margin:8px 0 0;"><a href="{{ .Block.LinkURL }}" style="text-decoration:underline;font-weight:600;color:{{ if eq .Block.Variant "solid" }}{{ .Values.Styles.ColorTextOnSolid }}{{ else }}{{ .Values.Styles.ColorPrimary }}{{ end }};">{{ .Block.LinkLabel }}</a></p>{{ end }}
</div>
