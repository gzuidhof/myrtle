<div style="margin:0 0 16px;padding:12px 14px;border:1px solid {{ .Values.Styles.BorderColor }};border-radius:8px;background:#ffffff;">
  {{ if .Block.Header }}<p style="margin:0 0 8px;font-weight:700;color:{{ .Values.Styles.TextColor }};">{{ .Block.Header }}</p>{{ end }}
  <p style="margin:0 0 6px;color:{{ .Values.Styles.TextColor }};font-size:14px;">{{ if .Block.Label }}{{ .Block.Label }}{{ end }}{{ if .Block.Value }}{{ if .Block.Label }}: {{ end }}<strong>{{ .Block.Value }}</strong>{{ end }}{{ if .Block.Delta }} <span style="color:{{ if eq .Block.DeltaSemantic "positive" }}#15803d{{ else if eq .Block.DeltaSemantic "negative" }}#b91c1c{{ else }}{{ .Values.Styles.MutedTextColor }}{{ end }};font-weight:{{ if eq .Block.DeltaSemantic "none" }}400{{ else }}600{{ end }};">({{ .Block.Delta }})</span>{{ end }}</p>
  {{ if .Block.Points }}
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;table-layout:fixed;">
    <tr>
      {{ range .Block.Points }}
      <td style="padding:0 1px;vertical-align:bottom;height:36px;">
        <div style="width:100%;height:{{ . }}px;max-height:36px;min-height:2px;background:{{ $.Values.Styles.PrimaryColor }};border-radius:2px;"></div>
      </td>
      {{ end }}
    </tr>
  </table>
  {{ end }}
</div>
