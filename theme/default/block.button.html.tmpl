<p style="margin:20px 0;text-align:{{ physicalAlign .Block.Alignment .Values }};">
  <a href="{{ .Block.URL }}" style="display:inline-block;max-width:100%;box-sizing:border-box;overflow-wrap:anywhere;word-break:break-word;word-wrap:break-word;{{ if eq .Block.Size "small" }}padding:8px 14px;font-size:13px;{{ else if eq .Block.Size "large" }}padding:12px 22px;font-size:16px;{{ else }}padding:10px 18px;font-size:14px;{{ end }}border-radius:{{ .Values.Styles.RadiusButton }};text-decoration:none;font-weight:600;{{ if .Block.NoWrap }}white-space:nowrap;overflow:hidden;text-overflow:ellipsis;{{ end }}{{ if .Block.FullWidth }}display:block;width:100%;max-width:100%;box-sizing:border-box;text-align:center;{{ end }}{{ if eq .Block.Style "outline" }}{{ if eq .Block.Tone "secondary" }}border:1px solid {{ .Values.Styles.ColorSecondary }};color:{{ .Values.Styles.ColorSecondary }};{{ else if eq .Block.Tone "danger" }}border:1px solid {{ .Values.Styles.ColorDanger }};color:{{ .Values.Styles.ColorDanger }};{{ else }}border:1px solid {{ .Values.Styles.ColorPrimary }};color:{{ .Values.Styles.ColorPrimary }};{{ end }}background:{{ .Values.Styles.ColorSurface }};{{ else if eq .Block.Style "ghost" }}background:transparent;{{ if eq .Block.Tone "secondary" }}color:{{ .Values.Styles.ColorSecondary }};{{ else if eq .Block.Tone "danger" }}color:{{ .Values.Styles.ColorDanger }};{{ else }}color:{{ .Values.Styles.ColorPrimary }};{{ end }}padding:0;{{ else }}{{ if eq .Block.Tone "secondary" }}background:{{ .Values.Styles.ColorSecondary }};{{ else if eq .Block.Tone "danger" }}background:{{ .Values.Styles.ColorDanger }};{{ else }}background:{{ .Values.Styles.ColorPrimary }};{{ end }}color:{{ .Values.Styles.ColorTextOnSolid }};{{ end }}">
    <span style="overflow-wrap:anywhere;word-break:break-word;">{{ .Block.Label }}</span>
  </a>
</p>