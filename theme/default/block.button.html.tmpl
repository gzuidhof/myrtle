<p style="margin:20px 0;{{ if eq .Block.Alignment "center" }}text-align:center;{{ else if eq .Block.Alignment "right" }}text-align:right;{{ else }}text-align:left;{{ end }}">
  <a href="{{ .Block.URL }}" style="display:inline-block;padding:10px 18px;border-radius:8px;text-decoration:none;font-weight:600;{{ if .Block.FullWidth }}display:block;width:100%;max-width:100%;box-sizing:border-box;text-align:center;{{ end }}{{ if eq .Block.Variant "secondary" }}border:1px solid {{ .Values.Styles.PrimaryColor }};background:#ffffff;color:{{ .Values.Styles.PrimaryColor }};{{ else if eq .Block.Variant "ghost" }}background:transparent;color:{{ .Values.Styles.PrimaryColor }};padding:0;{{ else }}background:{{ .Values.Styles.PrimaryColor }};color:#ffffff;{{ end }}">
    {{ .Block.Label }}
  </a>
</p>