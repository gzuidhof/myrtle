<div data-myrtle-vertical-bar-chart="1" style="margin:0 0 16px;">
  {{ if .Block.Header }}<p style="margin:0 0 10px;font-weight:700;color:{{ .Values.Styles.ColorText }};">{{ .Block.Header }}</p>{{ end }}

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin:0;">
    <tr>
      {{ if and .Block.ShowYTicks .Block.Ticks }}
      <td valign="top" width="{{ .Block.YAxisWidth }}" style="width:{{ .Block.YAxisWidth }}px;padding:0;vertical-align:top;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
          <tr>
            <td style="height:1px;line-height:1px;padding:0;text-align:right;border-top:1px solid {{ .Values.Styles.ColorBorder }};border-right:1px solid {{ .Values.Styles.ColorBorder }};font-size:0;"><span style="display:block;font-size:11px;line-height:1.2;color:{{ .Values.Styles.ColorTextMuted }};background:transparent;border:0;">{{ .Block.YAxisMaxLabel }}</span></td>
          </tr>
          {{ if gt .Block.PositiveHeight 0 }}
          <tr>
            <td valign="top" style="height:{{ .Block.PositiveHeight }}px;padding:0;vertical-align:top;text-align:right;font-size:11px;line-height:1.2;color:{{ .Values.Styles.ColorTextMuted }};border-right:1px solid {{ .Values.Styles.ColorBorder }};">&nbsp;</td>
          </tr>
          {{ end }}

          {{ if .Block.ShowYTicks }}
          <tr>
            <td style="height:1px;line-height:1px;padding:0;text-align:right;font-size:11px;color:{{ .Values.Styles.ColorTextMuted }};border-top:1px solid {{ .Values.Styles.ColorBorder }};border-right:1px solid {{ .Values.Styles.ColorBorder }};">{{ .Block.YAxisZeroLabel }}</td>
          </tr>
          {{ end }}

          {{ if gt .Block.NegativeHeight 0 }}
          <tr>
            <td style="height:{{ .Block.NegativeHeight }}px;padding:0;vertical-align:top;text-align:right;font-size:11px;line-height:1.2;color:{{ .Values.Styles.ColorTextMuted }};border-right:1px solid {{ .Values.Styles.ColorBorder }};">&nbsp;</td>
          </tr>
          {{ end }}
        </table>
      </td>
      {{ end }}
      <td valign="top" style="padding:0;vertical-align:top;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin:0;table-layout:fixed;">
          <tr>
            {{ range $columnIndex, $column := .Block.Columns }}
            {{ if and (gt $.Block.ColumnGap 0) (gt $columnIndex 0) }}
            <td valign="top" width="{{ $.Block.ColumnGap }}" style="width:{{ $.Block.ColumnGap }}px;padding:0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;width:100%;">
                {{ if gt $.Block.PositiveHeight 0 }}
                <tr>
                  <td style="height:{{ $.Block.PositiveHeight }}px;line-height:{{ $.Block.PositiveHeight }}px;font-size:0;padding:0;">&nbsp;</td>
                </tr>
                {{ end }}
                {{ if $.Block.ShowYTicks }}
                <tr>
                  <td style="height:1px;line-height:1px;font-size:0;padding:0;background:{{ $.Values.Styles.ColorBorder }};">&nbsp;</td>
                </tr>
                {{ end }}
                {{ if gt $.Block.NegativeHeight 0 }}
                <tr>
                  <td style="height:{{ $.Block.NegativeHeight }}px;line-height:{{ $.Block.NegativeHeight }}px;font-size:0;padding:0;">&nbsp;</td>
                </tr>
                {{ end }}
              </table>
            </td>
            {{ end }}
            <td valign="top" style="padding:0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;width:100%;{{ if $.Block.TransparentBackground }}background:transparent;{{ else }}background:{{ $.Values.Styles.ColorSurfaceMuted }};{{ end }}">
          {{ if gt $.Block.PositiveHeight 0 }}
          <tr>
            <td valign="bottom" style="height:{{ $.Block.PositiveHeight }}px;padding:0;vertical-align:bottom;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
                {{ if gt $column.PositiveTopPadding 0 }}
                <tr>
                  <td valign="bottom" style="height:{{ $column.PositiveTopPadding }}px;line-height:1.2;font-size:{{ if and $.Block.ShowValueLabels $column.PositiveAboveLabel }}10px{{ else }}0{{ end }};vertical-align:bottom;text-align:center;font-weight:700;font-family:Arial,sans-serif;mso-line-height-rule:exactly;color:{{ $.Values.Styles.ColorText }};">{{ if and $.Block.ShowValueLabels $column.PositiveAboveLabel }}{{ $column.PositiveAboveLabel }}{{ else }}&nbsp;{{ end }}</td>
                </tr>
                {{ end }}
                {{ range $column.PositiveSegments }}
                {{ if gt .Height 0 }}
                <tr>
                  <td title="{{ .Label }}: {{ .Display }}" valign="middle" style="height:{{ .Height }}px;line-height:{{ .Height }}px;font-size:{{ if and $.Block.ShowValueLabels (ge .Height $.Block.ValueLabelMinHeight) }}10px{{ else }}0{{ end }};vertical-align:middle;text-align:center;font-weight:700;font-family:Arial,sans-serif;mso-line-height-rule:exactly;color:{{ if .ValueLabelColor }}{{ .ValueLabelColor }}{{ else if $.Block.ValueLabelColor }}{{ $.Block.ValueLabelColor }}{{ else }}{{ $.Values.Styles.ColorTextOnSolid }}{{ end }};background:{{ if .Color }}{{ .Color }}{{ else if eq $.Block.Tone "muted" }}{{ $.Values.Styles.ColorTextMuted }}{{ else if eq $.Block.Tone "info" }}{{ $.Values.Styles.ColorInfo }}{{ else if eq $.Block.Tone "success" }}{{ $.Values.Styles.ColorSuccess }}{{ else if eq $.Block.Tone "warning" }}{{ $.Values.Styles.ColorWarning }}{{ else if eq $.Block.Tone "danger" }}{{ $.Values.Styles.ColorDanger }}{{ else }}{{ $.Values.Styles.ColorPrimary }}{{ end }};">{{ if and $.Block.ShowValueLabels (ge .Height $.Block.ValueLabelMinHeight) }}{{ .Display }}{{ else }}&nbsp;{{ end }}</td>
                </tr>
                {{ end }}
                {{ end }}
              </table>
            </td>
          </tr>
          {{ end }}

          {{ if $.Block.ShowYTicks }}
          <tr>
            <td style="height:1px;line-height:1px;font-size:0;background:{{ $.Values.Styles.ColorBorder }};">&nbsp;</td>
          </tr>
          {{ end }}

          {{ if gt $.Block.NegativeHeight 0 }}
          <tr>
            <td valign="top" style="height:{{ $.Block.NegativeHeight }}px;padding:0;vertical-align:top;">
              {{ if $column.NegativeSegments }}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
                {{ range $column.NegativeSegments }}
                {{ if gt .Height 0 }}
                <tr>
                  <td title="{{ .Label }}: {{ .SignedDisplay }}" valign="middle" style="height:{{ .Height }}px;line-height:{{ .Height }}px;font-size:{{ if and $.Block.ShowValueLabels (ge .Height $.Block.ValueLabelMinHeight) }}10px{{ else }}0{{ end }};vertical-align:middle;text-align:center;font-weight:700;font-family:Arial,sans-serif;mso-line-height-rule:exactly;color:{{ if .ValueLabelColor }}{{ .ValueLabelColor }}{{ else if $.Block.ValueLabelColor }}{{ $.Block.ValueLabelColor }}{{ else }}{{ $.Values.Styles.ColorTextOnSolid }}{{ end }};background:{{ if .Color }}{{ .Color }}{{ else if eq $.Block.Tone "muted" }}{{ $.Values.Styles.ColorTextMuted }}{{ else if eq $.Block.Tone "info" }}{{ $.Values.Styles.ColorInfo }}{{ else if eq $.Block.Tone "success" }}{{ $.Values.Styles.ColorSuccess }}{{ else if eq $.Block.Tone "warning" }}{{ $.Values.Styles.ColorWarning }}{{ else if eq $.Block.Tone "danger" }}{{ $.Values.Styles.ColorDanger }}{{ else }}{{ $.Values.Styles.ColorPrimary }}{{ end }};">{{ if and $.Block.ShowValueLabels (ge .Height $.Block.ValueLabelMinHeight) }}{{ .SignedDisplay }}{{ else }}&nbsp;{{ end }}</td>
                </tr>
                {{ end }}
                {{ end }}
              </table>
              {{ else }}
              <div style="height:{{ $.Block.NegativeHeight }}px;line-height:{{ $.Block.NegativeHeight }}px;font-size:0;">&nbsp;</div>
              {{ end }}
            </td>
          </tr>
          {{ end }}
        </table>

        {{ if $.Block.ShowCategoryLabels }}
    <p style="margin:6px 0 0;font-size:12px;line-height:1.3;color:{{ $.Values.Styles.ColorTextMuted }};text-align:center;">{{ $column.Label }}</p>
        {{ end }}
            </td>
            {{ end }}
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {{ if and (eq .Block.LegendPlacement "bottom") .Block.Legend }}
  <p style="margin:10px 0 0;font-size:12px;line-height:1.35;color:{{ .Values.Styles.ColorTextMuted }};">
    {{ range $index, $item := .Block.Legend }}
    {{ if $index }}&nbsp;&nbsp;{{ end }}
    <span style="white-space:nowrap;display:inline-block;">
      <span style="display:inline-block;width:9px;height:9px;background:{{ if $item.Color }}{{ $item.Color }}{{ else }}{{ $.Values.Styles.ColorPrimary }}{{ end }};vertical-align:middle;margin-right:4px;"></span>{{ $item.Label }}
    </span>
    {{ end }}
  </p>
  {{ end }}
</div>
