<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;mso-table-lspace:0pt;mso-table-rspace:0pt;margin:0 0 16px;">
  {{ $gapStart := halfFloor .Block.Gap }}
  {{ $gapEnd := halfCeil .Block.Gap }}
  {{ range $rowIndex, $row := .Rows }}
  <tr>
    {{ range $colIndex, $card := $row }}
    <td width="{{ $.ColumnWidth }}%" valign="top" style="padding:0;{{ if and (gt $.Block.Gap 0) (not (isLastRow $rowIndex (len $.Rows))) }}padding-bottom:{{ $.Block.Gap }}px;{{ end }}{{ if and (gt $.Block.Gap 0) (gt $colIndex 0) }}padding-{{ physicalSide "start" $.Values }}:{{ $gapStart }}px;{{ end }}{{ if and (gt $.Block.Gap 0) (not (isLastRow $colIndex (len $row))) }}padding-{{ physicalSide "end" $.Values }}:{{ $gapEnd }}px;{{ end }}">
      <div style="{{ if $.Block.Border }}border:1px solid {{ $.Values.Styles.ColorBorder }};{{ end }}border-radius:{{ if eq $.Block.InsetMode "none" }}0{{ else }}{{ $.Values.Styles.RadiusElement }}{{ end }};{{ if and $.Block.Border (eq $.Block.InsetMode "none") }}border-left:0;border-right:0;{{ end }}padding:12px;">
        {{ if $card.Title }}<p style="margin:0 0 6px;font-weight:700;color:{{ $.Values.Styles.ColorText }};">{{ $card.Title }}</p>{{ end }}
        {{ if $card.Subtitle }}<p style="margin:0 0 8px;font-size:13px;color:{{ $.Values.Styles.ColorTextMuted }};">{{ $card.Subtitle }}</p>{{ end }}
        {{ if $card.Body }}<p style="margin:0 0 10px;line-height:1.5;color:{{ $.Values.Styles.ColorText }};">{{ $card.Body }}</p>{{ end }}
        {{ if and $card.URL $card.CTALabel }}<p style="margin:0;"><a href="{{ $card.URL }}" style="color:{{ $.Values.Styles.ColorPrimary }};text-decoration:underline;">{{ $card.CTALabel }}</a></p>{{ else if $card.URL }}<p style="margin:0;"><a href="{{ $card.URL }}" style="color:{{ $.Values.Styles.ColorPrimary }};text-decoration:underline;">Open</a></p>{{ end }}
      </div>
    </td>
    {{ end }}
  </tr>
  {{ end }}
</table>
