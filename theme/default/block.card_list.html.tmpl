<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:separate;border-spacing:{{ .Block.Gap }}px;margin:0 0 16px;">
  {{ range .Rows }}
  <tr>
    {{ range . }}
    <td width="{{ $.ColumnWidth }}%" valign="top" style="padding:0;">
      <div style="{{ if $.Block.Border }}border:1px solid {{ $.Values.Styles.ColorBorder }};{{ end }}border-radius:{{ $.Values.Styles.RadiusElement }};padding:12px;">
        {{ if .Title }}<p style="margin:0 0 6px;font-weight:700;color:{{ $.Values.Styles.ColorText }};">{{ .Title }}</p>{{ end }}
        {{ if .Subtitle }}<p style="margin:0 0 8px;font-size:13px;color:{{ $.Values.Styles.ColorTextMuted }};">{{ .Subtitle }}</p>{{ end }}
        {{ if .Body }}<p style="margin:0 0 10px;line-height:1.5;color:{{ $.Values.Styles.ColorText }};">{{ .Body }}</p>{{ end }}
        {{ if and .URL .CTALabel }}<p style="margin:0;"><a href="{{ .URL }}" style="color:{{ $.Values.Styles.ColorPrimary }};text-decoration:underline;">{{ .CTALabel }}</a></p>{{ else if .URL }}<p style="margin:0;"><a href="{{ .URL }}" style="color:{{ $.Values.Styles.ColorPrimary }};text-decoration:underline;">Open</a></p>{{ end }}
      </div>
    </td>
    {{ end }}
  </tr>
  {{ end }}
</table>
