{{ if .Block.Header }}<p style="margin:0 0 8px;font-weight:700;color:{{ .Values.Styles.TextColor }};">{{ .Block.Header }}</p>{{ end }}
{{ if .Block.AggregateHeader }}<p style="margin:0 0 10px;color:{{ .Values.Styles.MutedTextColor }};font-size:13px;">{{ .Block.AggregateHeader }}</p>{{ end }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin:0 0 16px;">
  {{ range $index, $item := .Block.Items }}
  <tr>
    <td style="padding:8px 0;vertical-align:top;color:{{ $.Values.Styles.MutedTextColor }};font-size:13px;white-space:nowrap;{{ if eq $index $.Block.CurrentIndex }}font-weight:700;color:{{ $.Values.Styles.TextColor }};{{ end }}">{{ $item.Time }}</td>
    <td style="padding:8px 0 8px 12px;vertical-align:top;border-left:2px solid {{ if eq $index $.Block.CurrentIndex }}{{ $.Values.Styles.PrimaryColor }}{{ else }}{{ $.Values.Styles.BorderColor }}{{ end }};{{ if eq $index $.Block.CurrentIndex }}background:#f8fafc;{{ end }}">
      <p style="margin:0 0 4px;color:{{ $.Values.Styles.TextColor }};font-weight:{{ if eq $index $.Block.CurrentIndex }}700{{ else }}600{{ end }};">{{ $item.Title }}</p>
      {{ if $item.Detail }}<p style="margin:0;color:{{ $.Values.Styles.MutedTextColor }};font-size:14px;line-height:1.5;">{{ $item.Detail }}</p>{{ end }}
    </td>
  </tr>
  {{ end }}
</table>
