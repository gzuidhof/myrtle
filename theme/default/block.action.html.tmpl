<div style="margin:20px 0;padding:16px;">
  {{ if .Block.Instructions }}<p style="margin:0 0 12px;color:{{ .Values.Styles.TextColor }};line-height:1.5;">{{ .Block.Instructions }}</p>{{ end }}
  <p style="margin:0;">
    <a href="{{ .Block.ButtonURL }}" style="display:inline-block;padding:10px 18px;border-radius:6px;background:{{ .Values.Styles.PrimaryColor }};color:#ffffff;text-decoration:none;font-weight:600;">{{ .Block.ButtonLabel }}</a>
  </p>
</div>