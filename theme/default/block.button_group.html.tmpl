{{ if or .Block.StackOnMobile .Block.FullWidthOnMobile }}<style>@media only screen and (max-width:600px){ {{ if .Block.StackOnMobile }}.myrtle-btn-group-stack td{display:block !important;width:100% !important;padding-left:0 !important;}.myrtle-btn-group-stack td + td{padding-top:{{ .Block.Gap }}px !important;}.myrtle-btn-group-stack td a{display:block !important;width:100% !important;box-sizing:border-box !important;text-align:center !important;}{{ end }}{{ if .Block.FullWidthOnMobile }}.myrtle-btn-group-mobile-full td a{display:block !important;width:100% !important;box-sizing:border-box !important;text-align:center !important;}{{ end }} }</style>{{ end }}
<table role="presentation" cellpadding="0" cellspacing="0" class="{{ if .Block.StackOnMobile }}myrtle-btn-group-stack{{ end }}{{ if .Block.FullWidthOnMobile }}{{ if .Block.StackOnMobile }} {{ end }}myrtle-btn-group-mobile-full{{ end }}" style="margin:20px 0;{{ if eq .Block.Alignment "center" }}margin-left:auto;margin-right:auto;{{ else if eq .Block.Alignment "right" }}margin-left:auto;{{ end }}">
  <tr>
    {{ range $idx, $button := .Block.Buttons }}
    <td style="{{ if and (not $.Block.Joined) $idx }}padding-left:{{ $.Block.Gap }}px;{{ end }}">
      <a href="{{ $button.URL }}" style="display:inline-block;max-width:100%;box-sizing:border-box;white-space:nowrap;padding:10px 18px;text-decoration:none;font-weight:600;{{ if $.Block.Joined }}border-radius:0;{{ if eq $idx 0 }}border-top-left-radius:8px;border-bottom-left-radius:8px;{{ end }}{{ if isLastRow $idx (len $.Block.Buttons) }}border-top-right-radius:8px;border-bottom-right-radius:8px;{{ end }}{{ if $idx }}margin-left:-1px;{{ end }}{{ else }}border-radius:8px;{{ end }}{{ if eq $button.Style "outline" }}{{ if eq $button.Tone "secondary" }}border:1px solid {{ $.Values.Styles.ColorSecondary }};color:{{ $.Values.Styles.ColorSecondary }};{{ else if eq $button.Tone "danger" }}border:1px solid #dc2626;color:#dc2626;{{ else }}border:1px solid {{ $.Values.Styles.ColorPrimary }};color:{{ $.Values.Styles.ColorPrimary }};{{ end }}background:#ffffff;{{ else if eq $button.Style "ghost" }}{{ if $.Block.Joined }}{{ if eq $button.Tone "secondary" }}border:1px solid {{ $.Values.Styles.ColorSecondary }};{{ else if eq $button.Tone "danger" }}border:1px solid #dc2626;{{ else }}border:1px solid {{ $.Values.Styles.ColorPrimary }};{{ end }}{{ end }}background:transparent;{{ if eq $button.Tone "secondary" }}color:{{ $.Values.Styles.ColorSecondary }};{{ else if eq $button.Tone "danger" }}color:#dc2626;{{ else }}color:{{ $.Values.Styles.ColorPrimary }};{{ end }};{{ else }}{{ if $.Block.Joined }}{{ if eq $button.Tone "secondary" }}border:1px solid {{ $.Values.Styles.ColorSecondary }};{{ else if eq $button.Tone "danger" }}border:1px solid #dc2626;{{ else }}border:1px solid {{ $.Values.Styles.ColorPrimary }};{{ end }}{{ end }}{{ if eq $button.Tone "secondary" }}background:{{ $.Values.Styles.ColorSecondary }};{{ else if eq $button.Tone "danger" }}background:#dc2626;{{ else }}background:{{ $.Values.Styles.ColorPrimary }};{{ end }}color:#ffffff;{{ end }}">
        {{ $button.Label }}
      </a>
    </td>
    {{ end }}
  </tr>
</table>
