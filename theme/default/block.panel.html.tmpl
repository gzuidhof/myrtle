<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:separate;border-spacing:0;margin:0 0 16px;{{ if .Block.Border }}border:1px solid {{ .Values.Styles.ColorBorder }};{{ end }}border-radius:{{ if eq .Block.InsetMode "none" }}0{{ else }}{{ .Values.Styles.RadiusElement }}{{ end }};{{ if and .Block.Border (eq .Block.InsetMode "none") }}border-left:0;border-right:0;{{ end }}overflow:hidden;">
  <tr>
    {{ if .Block.ShowHeader }}
    <td style="padding:0;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;background:{{ .Values.Styles.ColorSurfaceMuted }};border-bottom:1px solid {{ .Values.Styles.ColorBorder }};">
        <tr>
          <td style="padding:12px 14px;">
            {{ if .Block.Category }}<p style="margin:0{{ if or .Block.Title .Block.Subtitle }} 0 4px{{ end }};font-size:12px;color:{{ .Values.Styles.ColorTextMuted }};text-transform:uppercase;letter-spacing:0.05em;">{{ .Block.Category }}</p>{{ end }}
            {{ if .Block.Title }}<p style="margin:0 0 2px;font-size:16px;font-weight:700;color:{{ .Values.Styles.ColorText }};">{{ .Block.Title }}</p>{{ end }}
            {{ if .Block.Subtitle }}<p style="margin:0;color:{{ .Values.Styles.ColorTextMuted }};line-height:1.5;">{{ .Block.Subtitle }}</p>{{ end }}
          </td>
        </tr>
      </table>
      <div style="padding:{{ .Block.Padding }}px {{ .Block.Padding }}px 0 {{ .Block.Padding }}px;">
        {{ safe .BodyHTML }}
      </div>
    </td>
    {{ else }}
    <td style="padding:{{ .Block.Padding }}px {{ .Block.Padding }}px 0 {{ .Block.Padding }}px;">
      {{ if .Block.Title }}<p style="margin:0 0 8px;font-size:16px;font-weight:700;color:{{ .Values.Styles.ColorText }};">{{ .Block.Title }}</p>{{ end }}
      {{ if .Block.Subtitle }}<p style="margin:0 0 12px;color:{{ .Values.Styles.ColorTextMuted }};line-height:1.5;">{{ .Block.Subtitle }}</p>{{ end }}
      {{ safe .BodyHTML }}
    </td>
    {{ end }}
  </tr>
</table>
