<div style="margin:0 0 16px;">
  {{ if .Block.Header }}<p style="margin:0 0 10px;font-weight:700;color:{{ .Values.Styles.ColorText }};">{{ .Block.Header }}</p>{{ end }}
  {{ range .Block.Items }}
  <div style="margin:0 0 10px;">
    <p style="margin:0 0 4px;color:{{ $.Values.Styles.ColorText }};font-size:13px;display:flex;gap:12px;">
      <span style="flex:1 1 auto;text-align:{{ physicalAlign "start" $.Values }};">{{ .Label }}</span>
      <span style="flex:1 1 auto;text-align:{{ physicalAlign "end" $.Values }};">{{ .Value }}</span>
    </p>
    <div style="height:8px;background:{{ $.Values.Styles.ColorSurfaceMuted }};border-radius:{{ $.Values.Styles.RadiusPill }};overflow:hidden;border:1px solid {{ $.Values.Styles.ColorBorder }};">
      <div style="height:100%;width:{{ .Percent }}%;background:{{ if .Color }}{{ .Color }}{{ else }}{{ $.Values.Styles.ColorPrimary }}{{ end }};"></div>
    </div>
  </div>
  {{ end }}
</div>
