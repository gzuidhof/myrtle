<blockquote style="margin:0 0 16px;padding:10px 14px;border-{{ physicalSide "start" .Values }}:4px solid {{ .Values.Styles.ColorBorder }};background:{{ .Values.Styles.ColorSurfaceMuted }};">
  <p style="margin:0 0 8px;color:{{ .Values.Styles.ColorText }};line-height:1.6;font-style:italic;">{{ .Block.Text }}</p>
  {{ if .Block.Author }}<p style="margin:0;color:{{ .Values.Styles.ColorTextMuted }};font-size:13px;">— {{ .Block.Author }}</p>{{ end }}
</blockquote>
