<div style="margin:0 0 16px;padding:14px 16px;border:1px solid {{ .Values.Styles.ColorBorder }};border-radius:12px;background:#ffffff;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
    <tr>
      {{ if .Block.AvatarURL }}
      <td valign="top" style="width:44px;padding:0 12px 0 0;">
          {{ if .Block.LogoHref }}<a href="{{ .Block.LogoHref }}" style="display:block;text-decoration:none;">{{ end }}
          <img src="{{ .Block.AvatarURL }}" alt="{{ .Block.LogoAlt }}" width="40" height="40" style="display:block;width:40px;height:40px;border-radius:12px;object-fit:cover;" />
          {{ if .Block.LogoHref }}</a>{{ end }}
      </td>
      {{ end }}
      <td valign="top" style="padding:0;">
        {{ if .SubjectHTML }}<div style="margin:0 0 6px;color:{{ .Values.Styles.ColorText }};font-weight:700;line-height:1.35;font-size:15px;">{{ if .Block.URL }}<a href="{{ .Block.URL }}" style="color:{{ .Values.Styles.ColorText }};text-decoration:none;">{{ .SubjectHTML }}</a>{{ else }}{{ .SubjectHTML }}{{ end }}</div>{{ end }}
        {{ if .PreviewHTML }}<div style="margin:0 0 8px;color:{{ .Values.Styles.ColorText }};line-height:1.55;font-size:14px;">{{ .PreviewHTML }}</div>{{ end }}
        {{ if or .MetaLine .JumpURL }}
        <p style="margin:0;color:{{ .Values.Styles.ColorTextMuted }};font-size:12px;line-height:1.4;">
          {{ if .MetaLine }}{{ .MetaLine }}{{ end }}{{ if .JumpURL }}{{ if .MetaLine }} · {{ end }}<a href="{{ .JumpURL }}" style="color:{{ .Values.Styles.ColorPrimary }};text-decoration:none;font-weight:600;">{{ .JumpLabel }}</a>{{ end }}
        </p>
        {{ end }}
        {{ if and .Block.ActionLabel .Block.ActionURL }}<p style="margin:10px 0 0;"><a href="{{ .Block.ActionURL }}" style="color:{{ .Values.Styles.ColorPrimary }};text-decoration:none;font-weight:600;">{{ .Block.ActionLabel }} →</a></p>{{ end }}
      </td>
    </tr>
  </table>
</div>
