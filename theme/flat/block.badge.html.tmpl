<p style="margin:0 0 12px;">
  <span style="display:inline-block;padding:3px 8px;border:1px solid {{ if eq .Block.Tone "success" }}#86efac{{ else if eq .Block.Tone "warning" }}#fcd34d{{ else if eq .Block.Tone "error" }}#fca5a5{{ else }}#93c5fd{{ end }};font-size:11px;font-weight:700;color:{{ .Values.Styles.ColorText }};">{{ .Block.Text }}</span>
</p>
