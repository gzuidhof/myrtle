<div style="margin:16px 0;padding:12px;">
  {{ if .Block.Instructions }}<p style="margin:0 0 10px;color:{{ .Values.Styles.TextColor }};line-height:1.4;">{{ .Block.Instructions }}</p>{{ end }}
  <p style="margin:0;">
    <a href="{{ .Block.ButtonURL }}" style="display:inline-block;padding:8px 14px;border:1px solid {{ .Values.Styles.PrimaryColor }};color:{{ .Values.Styles.PrimaryColor }};text-decoration:none;">{{ .Block.ButtonLabel }}</a>
  </p>
</div>