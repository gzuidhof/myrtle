{{ if .Block.Header }}<p style="margin:0 0 8px;font-weight:700;color:{{ .Values.Styles.ColorText }};">{{ .Block.Header }}</p>{{ end }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;table-layout:fixed;margin:0 0 14px;">
  {{ if .Block.Columns }}
  <tr>
    {{ range $columnIndex, $column := .Block.Columns }}
    {{ $alignment := index $.Block.ColumnAlignments $columnIndex }}
    <th align="{{ physicalAlign $alignment $.Values }}" style="padding:{{ if eq $.Block.Density "compact" }}5px 8px{{ else if eq $.Block.Density "relaxed" }}10px 12px{{ else }}8px 10px{{ end }};{{ if eq $.Block.HeaderTone "muted" }}border-bottom:2px {{ $.Block.BorderStyle }} {{ $.Values.Styles.ColorBorder }};background:{{ $.Values.Styles.ColorSurfaceMuted }};{{ else if eq $.Block.HeaderTone "plain" }}border-bottom:2px {{ $.Block.BorderStyle }} {{ $.Values.Styles.ColorBorder }};{{ else }}border-bottom:2px {{ $.Block.BorderStyle }} {{ $.Values.Styles.ColorPrimary }};{{ end }}font-size:12px;color:{{ $.Values.Styles.ColorText }};overflow-wrap:anywhere;word-break:break-word;word-wrap:break-word;text-align:{{ physicalAlign $alignment $.Values }};">{{ $column }}</th>
    {{ end }}
  </tr>
  {{ end }}
  {{ range $rowIndex, $row := .Block.Rows }}
  <tr>
    {{ range $columnIndex, $cell := $row }}
    {{ $alignment := index $.Block.ColumnAlignments $columnIndex }}
    <td style="padding:{{ if eq $.Block.Density "compact" }}5px 8px{{ else if eq $.Block.Density "relaxed" }}10px 12px{{ else }}8px 10px{{ end }};border-bottom:1px {{ $.Block.BorderStyle }} {{ $.Values.Styles.ColorBorder }};font-size:13px;color:{{ $.Values.Styles.ColorText }};overflow-wrap:anywhere;word-break:break-word;word-wrap:break-word;{{ if and $.Block.ZebraRows (isOdd $rowIndex) }}background:{{ $.Values.Styles.ColorSurfaceMuted }};{{ end }}{{ if and $.Block.EmphasizeTotalRow (isLastRow $rowIndex (len $.Block.Rows)) }}font-weight:700;background:{{ $.Values.Styles.ColorSurfaceMuted }};{{ end }}{{ if or (eq $alignment "center") (eq $alignment "start") (eq $alignment "end") }}text-align:{{ physicalAlign $alignment $.Values }};{{ else if and $.Block.RightAlignNumericColumns (isNumericLike $cell) }}text-align:{{ physicalAlign "end" $.Values }};{{ end }}">{{ $cell }}</td>
    {{ end }}
  </tr>
  {{ end }}
</table>