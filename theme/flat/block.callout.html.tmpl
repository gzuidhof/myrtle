<div style="margin:0 0 14px;padding:10px 12px;border:1px solid {{ if or (eq .Block.Type "error") (eq .Block.Type "critical") }}#fca5a5{{ else if eq .Block.Type "success" }}#86efac{{ else if eq .Block.Type "warning" }}#fcd34d{{ else }}#93c5fd{{ end }};{{ if eq .Block.Variant "solid" }}{{ if or (eq .Block.Type "error") (eq .Block.Type "critical") }}background:#dc2626;color:#ffffff;{{ else if eq .Block.Type "success" }}background:#16a34a;color:#ffffff;{{ else if eq .Block.Type "warning" }}background:#ca8a04;color:#ffffff;{{ else }}background:#2563eb;color:#ffffff;{{ end }}{{ else if eq .Block.Variant "soft" }}background:{{ if or (eq .Block.Type "error") (eq .Block.Type "critical") }}#fef2f2{{ else if eq .Block.Type "success" }}#f0fdf4{{ else if eq .Block.Type "warning" }}#fffbeb{{ else }}#eff6ff{{ end }};{{ end }}">
  {{ if .Block.Title }}<p style="margin:0 0 6px;font-weight:700;color:{{ if eq .Block.Variant "solid" }}#ffffff{{ else }}{{ .Values.Styles.TextColor }}{{ end }};">{{ .Block.Title }}</p>{{ end }}
  {{ if .Block.Body }}<p style="margin:0;color:{{ if eq .Block.Variant "solid" }}#ffffff{{ else }}{{ .Values.Styles.TextColor }}{{ end }};line-height:1.45;">{{ .Block.Body }}</p>{{ end }}
</div>
